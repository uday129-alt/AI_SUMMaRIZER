# Groq API Configuration
# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Groq Model Selection
# Options: llama-3.3-70b-versatile (recommended), llama3-8b-8192, mixtral-8x7b-32768, gemma-7b-it
GROQ_MODEL=llama-3.3-70b-versatile

# ============================================================================
# LangSmith Tracing Configuration (Optional but Recommended)
# ============================================================================
# LangSmith provides comprehensive observability and tracing for AI applications
# It tracks: prompts, responses, latency, errors, and complete execution traces
# 
# Benefits of LangSmith tracing:
# - Monitor all API calls and responses in real-time
# - Track performance metrics and latency
# - Debug errors with complete execution context
# - Analyze usage patterns
# - Production-ready observability
# 
# Setup:
# 1. Sign up for free at: https://smith.langchain.com/
# 2. Get your API key from: https://smith.langchain.com/settings/api-keys
# 3. Enable tracing by setting LANGSMITH_TRACING=true

# Enable tracing (true/false)
LANGSMITH_TRACING=true

# LangSmith API endpoint
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# LangSmith API key - Required if LANGSMITH_TRACING=true
# Get from: https://smith.langchain.com/settings/api-keys
LANGSMITH_API_KEY=your_langsmith_api_key_here

# Project name for organizing traces in LangSmith dashboard
LANGSMITH_PROJECT=AI_Summarizer
